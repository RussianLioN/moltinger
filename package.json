{
  "name": "moltinger",
  "version": "1.9.0",
  "description": "Infrastructure automation and deployment toolkit for self-hosted Moltis",
  "private": true,
  "scripts": {
    "test": "./tests/run_unit.sh --json",
    "test:integration": "./tests/run_integration.sh --json",
    "test:security": "./tests/run_security.sh --json",
    "test:e2e": "./tests/run_e2e.sh --json",
    "test:all": "npm run test && npm run test:integration && npm run test:security",
    "preflight": "./scripts/preflight-check.sh --ci --json",
    "scripts:verify": "./scripts/scripts-verify.sh"
  },
  "keywords": [
    "moltis",
    "docker",
    "deployment",
    "gitops",
    "monitoring",
    "backup",
    "devops"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RussianLioN/moltinger.git"
  },
  "bugs": {
    "url": "https://github.com/RussianLioN/moltinger/issues"
  },
  "homepage": "https://github.com/RussianLioN/moltinger",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
