{
  "name": "moltinger",
  "version": "1.9.0",
  "description": "Infrastructure automation and deployment toolkit for self-hosted Moltis",
  "private": true,
  "scripts": {
    "test": "./tests/run.sh --lane pr --json",
    "test:lane": "./tests/run.sh --json",
    "test:pr": "./tests/run.sh --lane pr --json",
    "test:main": "./tests/run.sh --lane main --json",
    "test:nightly": "./tests/run.sh --lane nightly --json --live",
    "test:all": "./tests/run.sh --lane all --json --live",
    "test:static": "./tests/run.sh --lane static --json",
    "test:component": "./tests/run.sh --lane component --json",
    "test:integration_local": "./tests/run.sh --lane integration_local --json",
    "test:security_api": "./tests/run.sh --lane security_api --json",
    "test:mcp_fake": "./tests/run.sh --lane mcp_fake --json",
    "test:e2e_browser": "./tests/run.sh --lane e2e_browser --json",
    "test:resilience": "./tests/run.sh --lane resilience --json --live",
    "test:live_external": "./tests/run.sh --lane live_external --json --live",
    "test:unit": "./tests/run.sh --lane unit_legacy --json",
    "test:integration": "./tests/run.sh --lane integration_legacy --json",
    "test:security": "./tests/run.sh --lane security_legacy --json",
    "test:e2e": "./tests/run.sh --lane e2e_legacy --json",
    "preflight": "./scripts/preflight-check.sh --ci --json",
    "scripts:verify": "./scripts/scripts-verify.sh"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0"
  },
  "keywords": [
    "moltis",
    "docker",
    "deployment",
    "gitops",
    "monitoring",
    "backup",
    "devops"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RussianLioN/moltinger.git"
  },
  "bugs": {
    "url": "https://github.com/RussianLioN/moltinger/issues"
  },
  "homepage": "https://github.com/RussianLioN/moltinger",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
