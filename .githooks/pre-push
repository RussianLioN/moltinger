#!/bin/bash
# Pre-push: Block push when branch/worktree session guard detects drift.

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=.githooks/_repo-local-path.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/_repo-local-path.sh"
GUARD_SCRIPT="$PROJECT_ROOT/scripts/git-session-guard.sh"
REGISTRY_SCRIPT="$PROJECT_ROOT/scripts/git-topology-registry.sh"

if [[ -x "$GUARD_SCRIPT" ]]; then
  "$GUARD_SCRIPT" --check --hook pre-push
fi

if [[ -x "$REGISTRY_SCRIPT" ]]; then
  if ! output="$("$REGISTRY_SCRIPT" check 2>&1)"; then
    printf '%s\n' "$output" >&2
    echo "[git-topology-registry] Push allowed with stale topology snapshot." >&2
    echo "[git-topology-registry] Ordinary branches do not own tracked snapshot publication." >&2
    echo "[git-topology-registry] Publish later from a dedicated non-main topology-publish worktree/branch via scripts/git-topology-registry.sh refresh --write-doc." >&2
  fi
fi

exit 0
