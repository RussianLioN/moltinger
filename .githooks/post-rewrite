#!/usr/bin/env bash
set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=.githooks/_repo-local-path.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/_repo-local-path.sh"
REGISTRY_SCRIPT="$PROJECT_ROOT/scripts/git-topology-registry.sh"

if [[ -x "$REGISTRY_SCRIPT" ]]; then
  if ! output="$("$REGISTRY_SCRIPT" check 2>&1)"; then
    printf '%s\n' "$output" >&2
    echo "[git-topology-registry] post-rewrite detected topology drift." >&2
    echo "[git-topology-registry] Ordinary branches may continue; local worktree and local-only branch topology remain live-only here." >&2
    echo "[git-topology-registry] Dispatch the shared publish flow later via scripts/git-topology-registry.sh publish if the tracked remote-governance snapshot needs refresh." >&2
  fi
fi

exit 0
