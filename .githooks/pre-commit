#!/bin/bash
# Pre-commit: Session state incremental update
# GitOps-compliant: Non-blocking, adds metadata only

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=.githooks/_repo-local-path.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/_repo-local-path.sh"
GUARD_SCRIPT="$PROJECT_ROOT/scripts/git-session-guard.sh"
NORMALIZE_SCRIPT="$PROJECT_ROOT/scripts/beads-normalize-issues-jsonl.sh"
PILOT_MODE_FILE="$PROJECT_ROOT/.beads/pilot-mode.json"
CUTOVER_MODE_FILE="$PROJECT_ROOT/.beads/cutover-mode.json"
PILOT_REVIEW_SCRIPT="$PROJECT_ROOT/scripts/beads-dolt-pilot.sh"
ROLLOUT_VERIFY_SCRIPT="$PROJECT_ROOT/scripts/beads-dolt-rollout.sh"
BEADS_AUDIT_SCRIPT="$PROJECT_ROOT/scripts/beads-worktree-audit.sh"
SESSION_FILE="$PROJECT_ROOT/SESSION_SUMMARY.md"
LOG_FILE="$PROJECT_ROOT/.tmp/sessions/precommit.log"

# Enforce branch/worktree session consistency before commit.
if [[ -x "$GUARD_SCRIPT" ]]; then
    if ! "$GUARD_SCRIPT" --check --hook pre-commit; then
        exit 1
    fi
fi

ACTIVE_MIGRATION_REVIEW_COMMAND=""
ACTIVE_MIGRATION_LABEL=""
if [[ -f "$CUTOVER_MODE_FILE" ]]; then
    ACTIVE_MIGRATION_LABEL="Cutover mode"
    ACTIVE_MIGRATION_REVIEW_COMMAND="./scripts/beads-dolt-rollout.sh verify --worktree ."
elif [[ -f "$PILOT_MODE_FILE" ]]; then
    ACTIVE_MIGRATION_LABEL="Pilot mode"
    ACTIVE_MIGRATION_REVIEW_COMMAND="./scripts/beads-dolt-pilot.sh review"
fi

if [[ -n "$ACTIVE_MIGRATION_LABEL" ]]; then
    if git diff --cached --name-only -- .beads/issues.jsonl | grep -q '^.beads/issues.jsonl$'; then
        echo "✗ ${ACTIVE_MIGRATION_LABEL} blocks staged .beads/issues.jsonl." >&2
        echo "  Use ${ACTIVE_MIGRATION_REVIEW_COMMAND} instead of committing JSONL-first review artifacts." >&2
        exit 1
    fi
fi
if [[ -x "$BEADS_AUDIT_SCRIPT" ]]; then
    if ! "$BEADS_AUDIT_SCRIPT" >/dev/null; then
        echo "✗ Sibling worktree Beads ownership audit failed." >&2
        echo "  Run ./scripts/beads-worktree-audit.sh from the canonical root and localize the reported worktrees." >&2
        exit 1
    fi
fi

if [[ -z "$ACTIVE_MIGRATION_LABEL" ]] && [[ -x "$NORMALIZE_SCRIPT" ]] && git ls-files --error-unmatch .beads/issues.jsonl >/dev/null 2>&1; then
    if git diff --cached --quiet -- .beads/issues.jsonl; then
        :
    elif ! git diff --quiet -- .beads/issues.jsonl; then
        echo "✗ Cannot auto-normalize partially staged .beads/issues.jsonl." >&2
        echo "  Stage the full file or stash the unstaged portion, then retry the commit." >&2
        exit 1
    elif ! "$NORMALIZE_SCRIPT" --check --path "$PROJECT_ROOT/.beads/issues.jsonl" >/dev/null 2>&1; then
        echo "🧹 Normalizing .beads/issues.jsonl dependency order"
        "$NORMALIZE_SCRIPT" --path "$PROJECT_ROOT/.beads/issues.jsonl" >/dev/null
        git add -- .beads/issues.jsonl
    fi
fi

# Create log directory if needed
mkdir -p "$(dirname "$LOG_FILE")"

# Get commit info
BRANCH=$(git branch --show-current)
TIMESTAMP=$(date +%H:%M:%S)
DATE=$(date +%Y-%m-%d)

# Get commit message from COMMIT_EDITMSG
COMMIT_MSG=$(head -1 "$PROJECT_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null || echo "commit")
COMMIT_SHORT=$(echo "$COMMIT_MSG" | head -c 60)

# Skip if SESSION_SUMMARY.md is in this commit (avoid loop)
if git diff --cached --name-only | grep -q "SESSION_SUMMARY.md"; then
    echo "📝 SESSION_SUMMARY.md in commit, skipping pre-commit update"
    exit 0
fi

# Log the commit (for /session-summary to process later)
echo "- [$DATE $TIMESTAMP] [$BRANCH] $COMMIT_SHORT" >> "$LOG_FILE"

echo "📝 Pre-commit logged: $COMMIT_SHORT"
exit 0
