# ===================================================================
# ASC AI Fabrique Demo - Example Environment
# ===================================================================
# Copy to .env.asc and fill with real values before deploy:
#   cp .env.asc.example .env.asc

# Public endpoint for demo adapter
ASC_DEMO_DOMAIN=demo.ainetic.tech
ASC_DEMO_PUBLIC_BASE_URL=https://demo.ainetic.tech
ASC_DEMO_PORT=18791
ASC_DEMO_INTERNAL_PORT=18791

# Controlled access gate
ASC_DEMO_ACCESS_MODE=shared_token_hash
# sha256 of demo access token (plain token never stored in git)
ASC_DEMO_SHARED_TOKEN_HASH=
ASC_DEMO_OPERATOR_LABEL=factory-demo-operator

# LLM orchestration for architect dialog
ASC_DEMO_LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
MODEL_NAME=accounts/fireworks/models/glm-5
ASC_DEMO_LLM_TIMEOUT_SECONDS=18
ASC_DEMO_LLM_TEMPERATURE=0.1
ASC_DEMO_LLM_MAX_TOKENS=350
