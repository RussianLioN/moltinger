{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "moltinger-scripts",
  "version": "1.1.0",
  "description": "Server automation scripts for Moltinger project",
  "maintainer": "DevOps Team",
  "repository": "https://github.com/RussianLioN/moltinger",
  "dependencies": {
    "system": {
      "docker": ">=20.10",
      "docker-compose": ">=2.0"
    },
    "packages": {
      "curl": "any",
      "jq": "any",
      "tar": "any",
      "gpg": "optional",
      "python3": "optional",
      "node": "optional"
    }
  },
  "deploy": {
    "target_path": "/opt/moltinger/scripts",
    "permissions": "755",
    "owner": "root",
    "sync_command": "gh workflow run deploy.yml (GitOps: scripts synced via CI/CD)",
    "note": "Manual scp disabled. All script changes must go through git push → CI/CD"
  },
  "systemd_units": {},
  "cron_jobs": {
    "moltis-backup-verify": {
      "source": "cron.d/moltis-backup-verify",
      "target": "/etc/cron.d/moltis-backup-verify",
      "schedule": "0 0 * * 0",
      "description": "Weekly backup integrity verification (Sunday 03:00 MSK)",
      "command": "/opt/moltinger/scripts/backup-moltis-enhanced.sh verify",
      "issue": "moltinger-hdn"
    },
    "moltis-telegram-webhook-monitor": {
      "source": "cron.d/moltis-telegram-webhook-monitor",
      "target": "/etc/cron.d/moltis-telegram-webhook-monitor",
      "schedule": "*/15 * * * *",
      "description": "Telegram webhook health and response quality monitoring",
      "command": "/opt/moltinger/scripts/telegram-webhook-monitor.sh --json",
      "issue": "moltinger-2kj"
    },
    "moltis-telegram-user-monitor": {
      "source": "cron.d/moltis-telegram-user-monitor",
      "target": "/etc/cron.d/moltis-telegram-user-monitor",
      "schedule": "*/10 * * * *",
      "description": "User-level Telegram probe and bot reply quality validation",
      "command": "/opt/moltinger/scripts/telegram-user-monitor.sh",
      "issue": "moltinger-2kj"
    },
    "moltis-codex-upstream-watcher": {
      "source": "cron.d/moltis-codex-upstream-watcher",
      "target": "/etc/cron.d/moltis-codex-upstream-watcher",
      "schedule": "17 */6 * * *",
      "description": "Moltis-native Codex update scheduler with duplicate-safe Telegram delivery",
      "command": "/opt/moltinger/scripts/moltis-codex-update-run.sh --mode scheduler --include-issue-signals --stdout none",
      "issue": "moltinger-eajx"
    }
  },
  "scripts": {
    "codex-check.sh": {
      "version": "1.0.0",
      "description": "Validate repo-specific Codex operating model and instruction governance",
      "entrypoint": true,
      "requires": [
        "bash"
      ],
      "provides": [
        "codex-check"
      ],
      "ci": true
    },
    "codex-profile-launch.sh": {
      "version": "1.1.0",
      "description": "Launch Codex with repo-specific sandbox, approval defaults, and optional update delivery hooks",
      "entrypoint": true,
      "requires": [
        "codex"
      ],
      "provides": [
        "codex-research",
        "codex-docs",
        "codex-runtime",
        "codex-assets",
        "codex-review",
        "codex-hotfix"
      ]
    },
    "beads-resolve-db.sh": {
      "version": "1.0.0",
      "description": "Resolve whether plain bd may use the current worktree-local tracker, pass through, or fail closed before root fallback",
      "entrypoint": true,
      "requires": [
        "bash",
        "git"
      ],
      "provides": [
        "beads-dispatch-resolve",
        "beads-root-fallback-guard"
      ]
    },
    "beads-worktree-localize.sh": {
      "version": "1.0.0",
      "description": "Remove stale Beads redirect metadata and bootstrap a worktree-local tracker database",
      "entrypoint": true,
      "requires": [
        "bash",
        "bd",
        "git"
      ],
      "provides": [
        "beads-worktree-localize"
      ]
    },
    "beads-normalize-issues-jsonl.sh": {
      "version": "1.0.0",
      "description": "Normalize tracked .beads/issues.jsonl dependency ordering into one deterministic canonical form",
      "entrypoint": true,
      "requires": [
        "bash",
        "python3",
        "mktemp"
      ],
      "provides": [
        "beads-issues-jsonl-normalize"
      ],
      "ci": true
    },
    "beads-recover-issue.sh": {
      "version": "1.0.0",
      "description": "Safely recover one leaked Beads issue into the localized tracker of the owner worktree",
      "entrypoint": true,
      "requires": [
        "bash",
        "bd",
        "git",
        "jq",
        "mktemp"
      ],
      "provides": [
        "beads-recover-issue"
      ]
    },
    "beads-recovery-batch.sh": {
      "version": "1.0.0",
      "description": "Audit and apply safe batch recovery of leaked Beads issues into owner worktrees",
      "entrypoint": true,
      "requires": [
        "bash",
        "bd",
        "git",
        "jq",
        "mktemp"
      ],
      "provides": [
        "beads-recovery-batch"
      ]
    },
    "bd-local.sh": {
      "version": "1.0.0",
      "description": "Fail-closed wrapper that binds Beads commands to the current worktree-local tracker database",
      "entrypoint": true,
      "requires": [
        "bash",
        "bd",
        "git"
      ],
      "provides": [
        "bd-local"
      ]
    },
    "telegram-bot-send-remote.sh": {
      "version": "1.1.0",
      "description": "Delegate Telegram bot sending with optional reply_markup payloads to the Moltinger server runtime over SSH",
      "entrypoint": true,
      "requires": [
        "ssh"
      ],
      "provides": [
        "telegram-bot-send-remote"
      ]
    },
    "codex-telegram-consent-store.sh": {
      "version": "1.0.0",
      "description": "Persist authoritative Codex Telegram consent records in a shared machine-readable store",
      "entrypoint": true,
      "requires": [
        "jq"
      ],
      "provides": [
        "codex-telegram-consent-store"
      ],
      "env_vars": [
        "CODEX_TELEGRAM_CONSENT_STORE_DIR"
      ],
      "ci": true
    },
    "moltis-codex-consent-router.sh": {
      "version": "1.0.0",
      "description": "Route tokenized Codex consent actions from Telegram into the authoritative shared consent store",
      "entrypoint": true,
      "requires": [
        "jq",
        "python3"
      ],
      "provides": [
        "moltis-codex-consent-router"
      ],
      "env_vars": [
        "CODEX_TELEGRAM_CONSENT_STORE_SCRIPT",
        "CODEX_TELEGRAM_CONSENT_STORE_DIR",
        "CODEX_TELEGRAM_CONSENT_ROUTER_SEND_SCRIPT",
        "CODEX_TELEGRAM_CONSENT_ROUTER_ENV_FILE",
        "CODEX_TELEGRAM_CONSENT_ROUTER_SEND_REPLY",
        "MOLTIS_ENV_FILE"
      ]
    },
    "moltis-codex-advisory-intake.sh": {
      "version": "1.0.0",
      "description": "Render or deliver a Moltis-native Codex advisory alert from a normalized producer event",
      "entrypoint": true,
      "requires": [
        "jq",
        "python3"
      ],
      "provides": [
