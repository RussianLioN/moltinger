      "env_vars": [
        "MOLTIS_CODEX_ADVISORY_EVENT_SCHEMA",
        "MOLTIS_CODEX_ADVISORY_SEND_ALERT",
        "MOLTIS_CODEX_ADVISORY_INTERACTIVE_MODE",
        "MOLTIS_CODEX_ADVISORY_TELEGRAM_CHAT_ID",
        "MOLTIS_CODEX_ADVISORY_TELEGRAM_ENV_FILE",
        "MOLTIS_CODEX_ADVISORY_TELEGRAM_SEND_SCRIPT",
        "MOLTIS_CODEX_ADVISORY_AUDIT_DIR",
        "MOLTIS_CODEX_ADVISORY_CALLBACK_PREFIX",
        "MOLTIS_CODEX_ADVISORY_DEGRADED_REASON",
        "MOLTIS_CODEX_ADVISORY_SESSION_STORE_SCRIPT",
        "MOLTIS_CODEX_ADVISORY_SESSION_STORE_DIR",
        "MOLTIS_CODEX_ADVISORY_CALLBACK_WINDOW_HOURS",
        "MOLTIS_CODEX_ADVISORY_RECOVERY_COMMAND"
      ],
      "ci": true
    },
    "codex-advisory-session-store.sh": {
      "version": "1.0.0",
      "description": "Persist Moltis-native Codex advisory sessions and their follow-up delivery state",
      "entrypoint": true,
      "requires": [
        "jq"
      ],
      "provides": [
        "codex-advisory-session-store"
      ],
      "env_vars": [
        "MOLTIS_CODEX_ADVISORY_SESSION_STORE_DIR"
      ],
      "ci": true
    },
    "moltis-codex-update-state.sh": {
      "version": "1.2.0",
      "description": "Persist Moltis-native Codex update skill state, scheduler checkpoints, delivery results, and audit pointers",
      "entrypoint": true,
      "requires": [
        "jq"
      ],
      "provides": [
        "moltis-codex-update-state"
      ],
      "env_vars": [
        "MOLTIS_CODEX_UPDATE_STATE_FILE"
      ],
      "ci": true
    },
    "moltis-codex-update-profile.sh": {
      "version": "1.1.0",
      "description": "Validate and normalize stable optional project profiles for the Moltis-native Codex update skill",
      "entrypoint": true,
      "requires": [
        "python3"
      ],
      "provides": [
        "moltis-codex-update-profile"
