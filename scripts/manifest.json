        "MOLTIS_CODEX_UPDATE_TELEGRAM_ENV_FILE",
        "MOLTIS_CODEX_UPDATE_TELEGRAM_SEND_SCRIPT",
        "MOLTIS_CODEX_UPDATE_TELEGRAM_SILENT"
      ],
      "ci": true
    },
    "moltis-codex-update-e2e.sh": {
      "version": "1.0.0",
      "description": "Run a hermetic Moltis-native Codex update proof covering manual profile handling, scheduler delivery, suppression, and audit evidence",
      "entrypoint": true,
      "requires": [
        "bash",
        "jq",
        "mktemp",
        "python3"
      ],
      "provides": [
        "moltis-codex-update-e2e"
      ],
      "ci": true
    },
    "moltis-codex-advisory-router.sh": {
      "version": "1.0.0",
      "description": "Route Moltis-native Codex advisory callbacks and recovery actions into immediate Telegram follow-up delivery",
