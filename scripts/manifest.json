      ],
      "ci": true
    },
    "moltis-codex-update-run.sh": {
      "version": "1.3.0",
      "description": "Canonical Moltis-native runtime entrypoint for on-demand and scheduled Codex CLI update checks with audit mirrors, scheduler-owned delivery, and profile-shaped recommendations",
      "entrypoint": true,
      "requires": [
        "bash",
