      ],
      "ci": true
    },
    "codex-telegram-consent-e2e.sh": {
      "version": "1.0.0",
      "description": "Run a hermetic Codex Telegram baseline check proving honest one-way alerts and degraded fallback without the retired repo-side consent UX",
