{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "moltinger-scripts",
  "version": "1.1.0",
  "description": "Server automation scripts for Moltinger project",
  "maintainer": "DevOps Team",
  "repository": "https://github.com/RussianLioN/moltinger",
  "scripts": {
    "backup-moltis-enhanced.sh": {
      "version": "3.0.0",
      "description": "Enterprise backup with encryption, offsite backup, integrity verification",
      "entrypoint": true,
      "requires": ["docker", "tar", "gpg"],
      "provides": ["backup", "restore", "verify", "list"],
      "cron": "0 2 * * *"
    },
    "build-lessons-index.sh": {
      "version": "1.0.0",
      "description": "Generate lessons learned index from RCA reports",
      "entrypoint": true,
      "requires": ["find", "grep", "sed", "cut", "sort"],
      "provides": ["build-lessons-index"]
    },
    "claude-rate-watch.sh": {
      "version": "1.0.0",
      "description": "Monitor Claude debug logs for rate limit status",
      "entrypoint": true,
      "requires": ["find", "grep", "awk"],
      "provides": ["rate-watch", "rate-watch-live", "rate-watch-stats"]
    },
    "deploy.sh": {
      "version": "2.2.0",
      "description": "Blue-green deployment with health checks, rollback, notifications",
      "entrypoint": true,
      "requires": ["docker", "docker-compose"],
      "provides": ["deploy", "rollback", "status", "start", "stop", "restart", "logs"],
      "gitops": true
    },
    "gitops-guards.sh": {
      "version": "1.0.0",
      "description": "GitOps compliance guard functions library",
      "entrypoint": false,
      "type": "library",
      "exports": [
        "gitops_is_ci",
        "gitops_confirm_manual",
        "gitops_log_action",
        "gitops_verify_file",
        "gitops_check_drift",
        "gitops_mark_manual",
        "gitops_guard_deploy",
        "gitops_guard_config"
      ]
    },
    "gitops-metrics.sh": {
      "version": "1.0.0",
      "description": "Collect and report GitOps compliance metrics",
      "entrypoint": true,
      "requires": ["sha256sum"],
      "provides": ["metrics", "slo", "report"],
      "slos": {
        "compliance_target": 95,
        "deploy_success_target": 99,
        "drift_detection_sla_minutes": 360
      },
      "cron": "0 * * * *"
    },
    "health-monitor.sh": {
      "version": "1.0.0",
      "description": "Health monitoring and alerting",
      "entrypoint": true,
      "requires": ["curl", "docker"],
      "provides": ["check", "watch", "alert"],
      "cron": "*/5 * * * *"
    },
    "ollama-health.sh": {
      "version": "1.0.0",
      "description": "Health checks for Ollama sidecar and fallback generation",
      "entrypoint": true,
      "requires": ["curl", "docker", "jq"],
      "provides": ["ollama-health", "ollama-health-json"]
    },
    "preflight-check.sh": {
      "version": "1.0.0",
      "description": "Pre-deployment validation for compose config and required secrets",
      "entrypoint": true,
      "requires": ["jq"],
      "provides": ["preflight-check", "preflight-json", "preflight-ci"],
      "ci": true
    },
    "query-lessons.sh": {
      "version": "1.0.0",
      "description": "Query RCA lessons by severity, tag, or category",
      "entrypoint": true,
      "requires": ["find", "grep", "sed"],
      "provides": ["query-lessons"]
    },
    "rate-check.sh": {
      "version": "1.0.0",
      "description": "Quick rate-limit check from Claude debug logs",
      "entrypoint": true,
      "requires": ["find", "grep", "awk"],
      "provides": ["rate-check", "rate-watch", "rate-alarm"]
    },
    "scripts-verify.sh": {
      "version": "1.0.0",
      "description": "Validate scripts manifest and verify integrity",
      "entrypoint": true,
      "requires": ["jq", "sha256sum"],
      "provides": ["verify", "validate"],
      "ci": true
    },
    "setup-git-hooks.sh": {
      "version": "1.0.0",
      "description": "Install repository git hooks for session management automation",
      "entrypoint": true,
      "requires": ["git"],
      "provides": ["setup-git-hooks"]
    },
    "sync-agent-instructions.sh": {
      "version": "1.0.0",
      "description": "Regenerate or check AGENTS.md from .ai instruction sources",
      "entrypoint": true,
      "requires": ["awk"],
      "provides": ["sync-agent-instructions", "check-agent-instructions"]
    },
    "sync-claude-skills-to-codex.sh": {
      "version": "1.0.0",
      "description": "Sync Claude bridge skills into Codex global skills directory",
      "entrypoint": true,
      "requires": ["find", "rsync"],
      "provides": ["sync-skills-install", "sync-skills-check"]
    },
    "test-moltis-api.sh": {
      "version": "1.0.0",
      "description": "Moltis HTTP API testing script",
      "entrypoint": true,
      "requires": ["curl", "jq"],
      "provides": ["test-api"],
      "env_vars": ["MOLTIS_URL", "MOLTIS_PASSWORD"]
    },
    "zai-rate-monitor.sh": {
      "version": "1.0.0",
      "description": "Monitor Z.ai Coding Plan API rate limits and output JSON for CI",
      "entrypoint": true,
      "requires": ["curl", "jq"],
      "provides": ["zai-rate-monitor", "zai-rate-watch", "zai-rate-json"]
    }
  },
  "dependencies": {
    "system": {
      "docker": ">=20.10",
      "docker-compose": ">=2.0"
    },
    "packages": {
      "curl": "any",
      "jq": "any",
      "tar": "any",
      "gpg": "optional"
    }
  },
  "deploy": {
    "target_path": "/opt/moltinger/scripts",
    "permissions": "755",
    "owner": "root",
    "sync_command": "gh workflow run deploy.yml (GitOps: scripts synced via CI/CD)",
    "note": "Manual scp disabled. All script changes must go through git push → CI/CD"
  },
  "cron_jobs": {
    "moltis-backup-verify": {
      "source": "cron.d/moltis-backup-verify",
      "target": "/etc/cron.d/moltis-backup-verify",
      "schedule": "0 0 * * 0",
      "description": "Weekly backup integrity verification (Sunday 03:00 MSK)",
      "command": "/opt/moltinger/scripts/backup-moltis-enhanced.sh verify",
      "issue": "moltinger-hdn"
    }
  }
}
