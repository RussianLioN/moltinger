# ===================================================================
# MCP Server Configuration - EXAMPLE FILE
# ===================================================================
# IMPORTANT: Copy this file to .env.local and fill in your actual credentials
# Command: cp .env.example .env.local
#
# .env.local is git-ignored and will NOT be committed to the repository

# ===================================================================
# Supabase Configuration
# ===================================================================
# Main Supabase Instance
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_PROJECT_REF=your-project-ref-here
SUPABASE_ACCESS_TOKEN=your-access-token-here
SUPABASE_DB_PASSWORD=your-database-password-here

# Legacy/Secondary Supabase Instance (optional)
SUPABASE_LEGACY_PROJECT_REF=your-legacy-project-ref-here

# ===================================================================
# Sequential Thinking MCP Server
# ===================================================================
# Get from: https://smithery.ai/
SEQUENTIAL_THINKING_KEY=your-smithery-api-key-here
SEQUENTIAL_THINKING_PROFILE=your-smithery-profile-here

# ===================================================================
# n8n Configuration
# ===================================================================
# Your n8n instance URL and API key
N8N_API_URL=https://your-n8n-instance.com
N8N_API_KEY=your-n8n-api-key-here

# ===================================================================
# GitHub Configuration (optional)
# ===================================================================
# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-token-here
GITHUB_PAT=your-github-pat-here

# ===================================================================
# Moltis Docker Deployment
# ===================================================================
# REQUIRED - Authentication
MOLTIS_PASSWORD=your-secure-password-here

# REQUIRED - LLM Provider (GLM-5 via Z.ai Coding Plan - OpenAI-compatible)
# Get API key at: https://open.bigmodel.cn/
# Uses Z.ai Coding Plan endpoint: https://api.z.ai/api/coding/paas/v4
# Pro subscription supports glm-5 model
GLM_API_KEY=your-zhipu-api-key-here

# ===================================================================
# Voice Configuration (Moltis TTS/STT)
# ===================================================================
# TTS: Piper (FREE, local) - No API key needed
# TTS: Silero via Coqui (FREE, local) - No API key needed

# Fallback: ElevenLabs (PAID, excellent quality)
# Get from: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# STT: Whisper.cpp (FREE, local) - No API key needed

# Fallback: Groq Whisper (Free tier available, very fast)
# Get from: https://console.groq.com/
# GROQ_API_KEY=gsk_your-groq-api-key-here

# Fallback: Mistral Voxtral (Free tier available)
# Get from: https://console.mistral.ai/
# MISTRAL_API_KEY=your-mistral-api-key-here

# ===================================================================
# Web Search Configuration (Moltis)
# ===================================================================
# RECOMMENDED: Tavily via MCP Server (1,000 free/month, NO credit card)
# Get from: https://tavily.com/ (sign up with email only)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# DISABLED: Brave Search (requires credit card since 2026)
# Get from: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-api-key-here

# FUTURE: SearXNG self-hosted (unlimited, completely free)
# Task tracked in backlog - will be deployed on same server

# ===================================================================
# Additional LLM Providers (Moltis)
# ===================================================================
# Anthropic Claude (Optional)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI (Optional)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# ===================================================================
# Telegram Bot Configuration (Moltis)
# ===================================================================
# REQUIRED for Telegram integration
# 1. Create bot via @BotFather in Telegram
# 2. Get token from BotFather response
# 3. Get your user ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ===================================================================
# OPTIONAL - Moltis Configuration
# ===================================================================
# MOLTIS_PORT=13131
# MOLTIS_HOST=0.0.0.0
# MOLTIS_NO_TLS=true
# MOLTIS_BEHIND_PROXY=true

# ===================================================================
# Notes
# ===================================================================
# - Never commit .env.local to git
# - Keep your tokens and passwords secure
# - Use environment-specific values for different setups
# - We use ONLY cloud Supabase, no local Docker instance
