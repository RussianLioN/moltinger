{
  "schema_version": "v1alpha1",
  "agent": {
    "agent_id": "clawdiy",
    "display_name": "Clawdiy",
    "role": "coder",
    "runtime_engine": "openclaw",
    "owner": "platform-ops",
    "lifecycle_state": "ready-for-deploy"
  },
  "server": {
    "bind": "0.0.0.0",
    "port": 18789,
    "base_url": "https://clawdiy.ainetic.tech",
    "health_path": "/health",
    "metrics_path": "/metrics"
  },
  "paths": {
    "config_root": "/home/node/.openclaw",
    "registry_root": "/home/node/.openclaw/registry",
    "state_root": "/home/node/.openclaw-data/state",
    "audit_root": "/home/node/.openclaw-data/audit"
  },
  "identity": {
    "domain": "clawdiy.ainetic.tech",
    "internal_endpoint": "http://clawdiy:18789/internal/v1",
    "telegram_bot": "@clawdiy_bot"
  },
  "control_plane": {
    "authoritative_transport": "http-json",
    "agent_id": "clawdiy",
    "reply_to": "agent://clawdiy",
    "submit_path": "/internal/v1/agent-handoffs",
    "ack_path_template": "/internal/v1/agent-handoffs/{correlation_id}/acks",
    "status_path_template": "/internal/v1/agent-handoffs/{correlation_id}",
    "cancel_path_template": "/internal/v1/agent-handoffs/{correlation_id}/cancel",
    "correlation_headers": {
      "authorization": "Authorization",
      "agent_id": "X-Agent-Id",
      "correlation_id": "X-Correlation-Id",
      "idempotency_key": "Idempotency-Key"
    },
    "acknowledgement_callbacks": {
      "delivery": "POST /internal/v1/agent-handoffs/{correlation_id}/acks",
      "accept": "POST /internal/v1/agent-handoffs/{correlation_id}/acks",
      "start": "POST /internal/v1/agent-handoffs/{correlation_id}/acks",
      "progress": "POST /internal/v1/agent-handoffs/{correlation_id}/acks",
      "terminal": "POST /internal/v1/agent-handoffs/{correlation_id}/acks",
      "cancel": "POST /internal/v1/agent-handoffs/{correlation_id}/cancel"
    },
    "required_ack_types": [
      "delivery",
      "accept",
      "start",
      "terminal"
    ],
    "registry_path": "/home/node/.openclaw/registry/agents-registry.json",
    "policy_path": "/home/node/.openclaw/registry/policy.json",
    "delivery_ack_deadline_seconds": 10,
    "start_ack_deadline_seconds": 60,
    "progress_heartbeat_seconds": 300,
    "terminal_timeout_seconds": 900
  },
  "auth": {
    "human_auth_secret_ref": "github-secret:CLAWDIY_PASSWORD",
    "service_auth_secret_ref": "github-secret:CLAWDIY_SERVICE_TOKEN",
    "telegram_token_ref": "github-secret:CLAWDIY_TELEGRAM_BOT_TOKEN",
    "provider_auth_profiles": {
      "openai-codex": {
        "enabled": false,
        "rollout_gate": "post-auth-verify"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "mode": "polling",
      "bot_username": "@clawdiy_bot",
      "token_ref": "github-secret:CLAWDIY_TELEGRAM_BOT_TOKEN"
    }
  },
  "storage": {
    "audit_format": "jsonl",
    "state_snapshot_prefix": "clawdiy"
  }
}
