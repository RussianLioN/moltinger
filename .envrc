# Prefer the repo-local plain `bd` shim inside this worktree.
repo_root="$(git rev-parse --show-toplevel)"
if [[ ":${PATH}:" != *":${repo_root}/bin:"* ]]; then
  export PATH="${repo_root}/bin:${PATH}"
fi

# Migration review surfaces stay explicit:
# - pilot mode: ./scripts/beads-dolt-pilot.sh review
# - cutover mode: ./scripts/beads-dolt-rollout.sh verify --worktree .

# Load Supabase MCP credentials
source ~/.config/supabase/mcp.env
