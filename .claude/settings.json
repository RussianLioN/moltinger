{
  "plansDirectory": "./docs/plans",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker", "git", "ssh", "scp", "rsync"],
    "filesystem": {
      "write": {
        "allowOnly": [
          "/dev/stdout",
          "/dev/stderr",
          "/dev/null",
          "/dev/tty",
          "/dev/dtracehelper",
          "/dev/autofs_nowait",
          "/tmp/claude",
          "/private/tmp/claude",
          "/Users/rl/.npm/_logs",
          "/Users/rl/.claude/debug",
          "/Users/rl/.beads",
          "/Users/rl/.beads/",
          "/Users/rl/.beads/**",
          ".",
          "/private/tmp/claude-501/"
        ]
      },
      "read": {
        "allowOnly": [
          "/Users/rl/.beads",
          "/Users/rl/.beads/",
          "/Users/rl/.beads/**",
          "."
        ]
      }
    }
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/worktree-setup.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(bd *)",
      "Bash(ssh *)",
      "WebFetch",
      "Read",
      "mcp__context7__*"
    ],
    "ask": [
      "Bash(docker build *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Edit(./.github/workflows/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./config/provider_keys.json)",
      "Bash(rm -rf *)"
    ]
  }
}
