<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" 
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" 
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" 
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="Definitions_N8N_Prototype" 
             targetNamespace="http://bpmn.io/bpmn" 
             exporter="Manual BPMN Generator" 
             exporterVersion="1.0">
  
  <process id="Process_N8N_Prototyping" name="N8N-based AI Prototyping Solution" isExecutable="false">
    
    <!-- Старт процесса -->
    <startEvent id="StartEvent_1" name="Начало&#10;процесса">
      <outgoing>Flow_01</outgoing>
    </startEvent>
    
    <!-- Шаг 1: Авторизация и аутентификация -->
    <userTask id="Task_Auth" name="Авторизация и аутентификация">
      <incoming>Flow_01</incoming>
      <outgoing>Flow_02</outgoing>
    </userTask>
    
    <!-- Шаг 2: Настройка токенов -->
    <task id="Task_TokenSetup" name="Настройка токенов и тузов (SecMan)">
      <incoming>Flow_02</incoming>
      <outgoing>Flow_03</outgoing>
    </task>
    
    <!-- Шаг 3: Ввод промпта -->
    <userTask id="Task_PromptInput" name="Ввод промпта (макс 32768 токенов)">
      <incoming>Flow_03</incoming>
      <outgoing>Flow_04</outgoing>
    </userTask>
    
    <!-- Шаг 4: NLP анализ контекста -->
    <task id="Task_NLP" name="Контекстный анализ (NLP модель)">
      <incoming>Flow_04</incoming>
      <outgoing>Flow_05</outgoing>
    </task>
    
    <!-- Шаг 5: RAG поиск в Qdrant -->
    <task id="Task_RAG" name="Поиск сущностей в Qdrant (RAG + META)">
      <incoming>Flow_05</incoming>
      <outgoing>Flow_06</outgoing>
    </task>
    
    <!-- Шаг 6: Генерация прототипа -->
    <task id="Task_Prototype" name="Генерация шаблонов классов">
      <incoming>Flow_06</incoming>
      <outgoing>Flow_07</outgoing>
    </task>
    
    <!-- Шаг 7: Git commit прототипа -->
    <task id="Task_GitCommit1" name="Git commit в ветку dev">
      <incoming>Flow_07</incoming>
      <outgoing>Flow_08</outgoing>
    </task>
    
    <!-- Шаг 8: Реализация заглушек -->
    <task id="Task_Stubs" name="Реализация заглушек (признак dev)">
      <incoming>Flow_08</incoming>
      <outgoing>Flow_09</outgoing>
    </task>
    
    <!-- Шаг 9: Git commit заглушек -->
    <task id="Task_GitCommit2" name="Git commit заглушек в dev">
      <incoming>Flow_09</incoming>
      <outgoing>Flow_10</outgoing>
    </task>
    
    <!-- Шаг 10: GLM-4.6 обработка бизнес-логики -->
    <task id="Task_GLM" name="GLM-4.6: разработка бизнес-логики">
      <incoming>Flow_10</incoming>
      <incoming>Flow_FixCode</incoming>
      <incoming>Flow_FixUnitTests</incoming>
      <outgoing>Flow_11</outgoing>
    </task>
    
    <!-- Шаг 11: Git commit логики -->
    <task id="Task_GitCommit3" name="Git commit бизнес-логики в dev">
      <incoming>Flow_11</incoming>
      <outgoing>Flow_12</outgoing>
    </task>
    
    <!-- Шаг 12: Сбор метаинформации -->
    <task id="Task_Metadata" name="Сбор метаинформации (библиотеки, методы)">
      <incoming>Flow_12</incoming>
      <incoming>Flow_FixLibraries</incoming>
      <outgoing>Flow_13</outgoing>
    </task>
    
    <!-- Шаг 13: Верификация библиотек на MCP -->
    <task id="Task_LibVerification" name="Верификация библиотек на MCP-сервере">
      <incoming>Flow_13</incoming>
      <outgoing>Flow_14</outgoing>
    </task>
    
    <!-- Шлюз 1: Проверка библиотек -->
    <exclusiveGateway id="Gateway_LibCheck" name="Библиотеки&#10;валидны?">
      <incoming>Flow_14</incoming>
      <outgoing>Flow_15_Pass</outgoing>
      <outgoing>Flow_15_Fail</outgoing>
    </exclusiveGateway>
    
    <!-- Фиксация проблем с библиотеками -->
    <task id="Task_LibFix" name="Поиск альтернативных библиотек">
      <incoming>Flow_15_Fail</incoming>
      <outgoing>Flow_FixLibraries</outgoing>
    </task>
    
    <!-- Шаг 14: Верификация кода -->
    <task id="Task_CodeValidation" name="Верификация кода (SonarQube, Checkmarx, SCA, SAST)">
      <incoming>Flow_15_Pass</incoming>
      <outgoing>Flow_16</outgoing>
    </task>
    
    <!-- Шлюз 2: Проверка кода -->
    <exclusiveGateway id="Gateway_CodeCheck" name="Код&#10;валиден?">
      <incoming>Flow_16</incoming>
      <outgoing>Flow_17_Pass</outgoing>
      <outgoing>Flow_17_Fail</outgoing>
    </exclusiveGateway>
    
    <!-- Фиксация проблем с кодом -->
    <task id="Task_CodeFix" name="Исправление ошибок кода">
      <incoming>Flow_17_Fail</incoming>
      <outgoing>Flow_FixCode</outgoing>
    </task>
    
    <!-- Шаг 15: Unit тестирование -->
    <task id="Task_UnitTests" name="Генерация и выполнение Unit Test Case">
      <incoming>Flow_17_Pass</incoming>
      <outgoing>Flow_18</outgoing>
    </task>
    
    <!-- Шлюз 3: Проверка unit-тестов -->
    <exclusiveGateway id="Gateway_TestCheck" name="Тесты&#10;100% OK?">
      <incoming>Flow_18</incoming>
      <outgoing>Flow_19_Pass</outgoing>
      <outgoing>Flow_19_Fail</outgoing>
    </exclusiveGateway>
    
    <!-- Фиксация проблем с тестами -->
    <task id="Task_TestFix" name="Исправление тестов">
      <incoming>Flow_19_Fail</incoming>
      <outgoing>Flow_FixUnitTests</outgoing>
    </task>
    
    <!-- Шаг 16: Подготовка финального прототипа -->
    <task id="Task_FinalPrep" name="Подготовка финального прототипа">
      <incoming>Flow_19_Pass</incoming>
      <outgoing>Flow_20</outgoing>
    </task>
    
    <!-- Шаг 17: Удаление DEV-флага -->
    <task id="Task_RemoveDev" name="Удаление признака dev">
      <incoming>Flow_20</incoming>
      <outgoing>Flow_21</outgoing>
    </task>
    
    <!-- Шаг 18: Git commit в PSI -->
    <task id="Task_GitCommitPSI" name="Git commit в ветку ПСИ">
      <incoming>Flow_21</incoming>
      <outgoing>Flow_22</outgoing>
    </task>
    
    <!-- Завершение процесса -->
    <endEvent id="EndEvent_1" name="Прототип&#10;готов">
      <incoming>Flow_22</incoming>
    </endEvent>
    
    <!-- Sequence Flows -->
    <sequenceFlow id="Flow_01" sourceRef="StartEvent_1" targetRef="Task_Auth"/>
    <sequenceFlow id="Flow_02" sourceRef="Task_Auth" targetRef="Task_TokenSetup"/>
    <sequenceFlow id="Flow_03" sourceRef="Task_TokenSetup" targetRef="Task_PromptInput"/>
    <sequenceFlow id="Flow_04" sourceRef="Task_PromptInput" targetRef="Task_NLP"/>
    <sequenceFlow id="Flow_05" sourceRef="Task_NLP" targetRef="Task_RAG"/>
    <sequenceFlow id="Flow_06" sourceRef="Task_RAG" targetRef="Task_Prototype"/>
    <sequenceFlow id="Flow_07" sourceRef="Task_Prototype" targetRef="Task_GitCommit1"/>
    <sequenceFlow id="Flow_08" sourceRef="Task_GitCommit1" targetRef="Task_Stubs"/>
    <sequenceFlow id="Flow_09" sourceRef="Task_Stubs" targetRef="Task_GitCommit2"/>
    <sequenceFlow id="Flow_10" sourceRef="Task_GitCommit2" targetRef="Task_GLM"/>
    <sequenceFlow id="Flow_11" sourceRef="Task_GLM" targetRef="Task_GitCommit3"/>
    <sequenceFlow id="Flow_12" sourceRef="Task_GitCommit3" targetRef="Task_Metadata"/>
    <sequenceFlow id="Flow_13" sourceRef="Task_Metadata" targetRef="Task_LibVerification"/>
    <sequenceFlow id="Flow_14" sourceRef="Task_LibVerification" targetRef="Gateway_LibCheck"/>
    
    <sequenceFlow id="Flow_15_Pass" name="Да" sourceRef="Gateway_LibCheck" targetRef="Task_CodeValidation"/>
    <sequenceFlow id="Flow_15_Fail" name="Нет" sourceRef="Gateway_LibCheck" targetRef="Task_LibFix"/>
    <sequenceFlow id="Flow_FixLibraries" sourceRef="Task_LibFix" targetRef="Task_Metadata"/>
    
    <sequenceFlow id="Flow_16" sourceRef="Task_CodeValidation" targetRef="Gateway_CodeCheck"/>
    <sequenceFlow id="Flow_17_Pass" name="Да" sourceRef="Gateway_CodeCheck" targetRef="Task_UnitTests"/>
    <sequenceFlow id="Flow_17_Fail" name="Нет" sourceRef="Gateway_CodeCheck" targetRef="Task_CodeFix"/>
    <sequenceFlow id="Flow_FixCode" sourceRef="Task_CodeFix" targetRef="Task_GLM"/>
    
    <sequenceFlow id="Flow_18" sourceRef="Task_UnitTests" targetRef="Gateway_TestCheck"/>
    <sequenceFlow id="Flow_19_Pass" name="Да" sourceRef="Gateway_TestCheck" targetRef="Task_FinalPrep"/>
    <sequenceFlow id="Flow_19_Fail" name="Нет" sourceRef="Gateway_TestCheck" targetRef="Task_TestFix"/>
    <sequenceFlow id="Flow_FixUnitTests" sourceRef="Task_TestFix" targetRef="Task_GLM"/>
    
    <sequenceFlow id="Flow_20" sourceRef="Task_FinalPrep" targetRef="Task_RemoveDev"/>
    <sequenceFlow id="Flow_21" sourceRef="Task_RemoveDev" targetRef="Task_GitCommitPSI"/>
    <sequenceFlow id="Flow_22" sourceRef="Task_GitCommitPSI" targetRef="EndEvent_1"/>
    
  </process>
  
