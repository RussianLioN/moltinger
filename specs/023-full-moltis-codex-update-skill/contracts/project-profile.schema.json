{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltinger/specs/023-full-moltis-codex-update-skill/contracts/project-profile.schema.json",
  "title": "Codex Update Project Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "project_name",
    "traits",
    "relevance_rules"
  ],
  "properties": {
    "schema_version": {
      "const": "codex-update-project-profile/v1"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "traits": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relevance_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "keywords",
          "title_ru",
          "rationale_ru",
          "next_steps_ru"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "title_ru": {
            "type": "string",
            "minLength": 1
          },
          "rationale_ru": {
            "type": "string",
            "minLength": 1
          },
          "next_steps_ru": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "recommendation_template_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "recommendation_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title_ru",
          "rationale_ru",
          "next_steps_ru"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title_ru": {
            "type": "string",
            "minLength": 1
          },
          "rationale_ru": {
            "type": "string",
            "minLength": 1
          },
          "next_steps_ru": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "impacted_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "fallback_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title_ru",
        "rationale_ru",
        "next_steps_ru"
      ],
      "properties": {
        "title_ru": {
          "type": "string",
          "minLength": 1
        },
        "rationale_ru": {
          "type": "string",
          "minLength": 1
        },
        "next_steps_ru": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "impacted_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
