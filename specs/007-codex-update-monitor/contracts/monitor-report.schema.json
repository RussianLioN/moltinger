{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltinger/specs/007-codex-update-monitor/contracts/monitor-report.schema.json",
  "title": "Codex CLI Update Monitor Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checked_at",
    "local_version",
    "latest_version",
    "version_status",
    "local_features",
    "repo_workflow_traits",
    "sources",
    "relevant_changes",
    "non_relevant_changes",
    "recommendation",
    "evidence",
    "issue_action"
  ],
  "properties": {
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "local_version": {
      "type": "string",
      "minLength": 1
    },
    "latest_version": {
      "type": "string",
      "minLength": 1
    },
    "version_status": {
      "type": "string",
      "enum": [
        "ahead",
        "current",
        "behind",
        "unknown"
      ]
    },
    "local_features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "repo_workflow_traits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_source",
        "issue_signals_included"
      ],
      "properties": {
        "release_source": {
          "type": "string",
          "minLength": 1
        },
        "issue_signals_included": {
          "type": "boolean"
        },
        "issue_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "relevant_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "non_relevant_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change"
      }
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "upgrade-now",
        "upgrade-later",
        "ignore",
        "investigate"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "issue_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "requested"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "suggested",
            "created",
            "updated",
            "skipped"
          ]
        },
        "requested": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "relevance",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "relevance": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "none"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
