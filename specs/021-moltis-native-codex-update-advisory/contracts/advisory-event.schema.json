{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltinger/specs/021-moltis-native-codex-update-advisory/contracts/advisory-event.schema.json",
  "title": "Codex Advisory Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "created_at",
    "source",
    "upstream_fingerprint",
    "latest_version",
    "severity",
    "summary_ru",
    "highlights_ru",
    "recommendation_status"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "codex-cli-upstream-watcher"
      ]
    },
    "upstream_fingerprint": {
      "type": "string",
      "minLength": 8
    },
    "latest_version": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "normal",
        "important",
        "critical",
        "investigate"
      ]
    },
    "summary_ru": {
      "type": "string",
      "minLength": 1
    },
    "highlights_ru": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendation_status": {
      "type": "string",
      "enum": [
        "ready",
        "deferred",
        "unavailable"
      ]
    },
    "recommendation_payload": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "headline_ru": {
          "type": "string"
        },
        "summary_ru": {
          "type": "string"
        },
        "priority_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impacted_surfaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw_reference_path": {
          "type": "string"
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "url"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
