{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moltinger/specs/012-codex-upstream-watcher/contracts/watcher-report.schema.json",
  "title": "Codex Upstream Watcher Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checked_at",
    "feature_explanation",
    "snapshot",
    "fingerprint",
    "severity",
    "decision",
    "advisor_bridge",
    "telegram_target",
    "followup",
    "automation",
    "state",
    "notes"
  ],
  "properties": {
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "feature_explanation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "snapshot": {
      "$ref": "#/$defs/snapshot"
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "$ref": "#/$defs/severity"
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "advisor_bridge": {
      "$ref": "#/$defs/advisor_bridge"
    },
    "telegram_target": {
      "$ref": "#/$defs/telegram_target"
    },
    "followup": {
      "$ref": "#/$defs/followup"
    },
    "automation": {
      "$ref": "#/$defs/automation"
    },
    "state": {
      "$ref": "#/$defs/state"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "url",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["ok", "investigate", "unavailable"]
        },
        "url": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "advisory_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "state", "url"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string"
        }
      }
    },
    "recent_release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "published_at",
        "change_count",
        "headline",
        "explanations",
        "severity"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": "string"
        },
        "change_count": {
          "type": "integer",
          "minimum": 0
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "explanations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity": {
          "type": "string",
          "enum": ["info", "important", "critical"]
        }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latest_version",
        "release_status",
        "primary_source",
        "advisory_sources",
        "advisory_items",
        "highlights",
        "highlight_explanations",
        "recent_releases"
      ],
      "properties": {
        "latest_version": {
          "type": "string",
          "minLength": 1
        },
        "release_status": {
          "type": "string",
          "enum": ["new", "known", "investigate", "unavailable"]
        },
        "primary_source": {
          "$ref": "#/$defs/source"
        },
        "advisory_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "advisory_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/advisory_item"
          }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "highlight_explanations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recent_releases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recent_release"
          }
        }
      }
    },
    "severity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "reason"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["info", "important", "critical", "investigate"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "changed", "delivery_mode"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["deliver", "suppress", "retry", "investigate", "queued"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "changed": {
          "type": "boolean"
        },
        "delivery_mode": {
          "type": "string",
          "enum": ["immediate", "digest"]
        }
      }
    },
    "practical_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "priority", "rationale", "impacted_paths", "next_steps"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "impacted_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "advisor_bridge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "status", "summary", "top_priorities", "practical_recommendations", "notes", "question"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": ["disabled", "unavailable", "investigate", "ready"]
        },
        "summary": {
          "type": "string"
        },
        "top_priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "practical_recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/practical_recommendation"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "question": {
          "type": "string"
        }
      }
    },
    "digest_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "version", "checked_at", "headline", "severity", "explanations"],
      "properties": {
        "fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "checked_at": {
          "type": "string"
        },
        "headline": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["info", "important", "critical"]
        },
        "explanations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pending_consent_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "chat_id", "asked_at", "expires_at", "question", "summary", "status", "recommendations"],
      "properties": {
        "fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "chat_id": {
          "type": "string",
          "minLength": 1
        },
        "asked_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending"]
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/practical_recommendation"
          }
        }
      }
    },
    "followup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "consent"],
      "properties": {
        "digest": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "pending_count", "last_sent_at", "pending_items"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["immediate", "digest"]
            },
            "pending_count": {
              "type": "integer",
              "minimum": 0
            },
            "last_sent_at": {
              "type": "string"
            },
            "next_send_after": {
              "type": "string"
            },
            "pending_items": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/digest_entry"
              }
            }
          }
        },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reason", "expires_at", "question", "pending_state"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["disabled", "none", "pending", "accepted", "declined", "sent", "expired", "investigate"]
            },
            "reason": {
              "type": "string"
            },
            "expires_at": {
              "type": "string"
            },
            "question": {
              "type": "string"
            },
            "pending_state": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "$ref": "#/$defs/pending_consent_state"
                }
              ]
            }
          }
        }
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alert", "recommendations"],
      "properties": {
        "alert": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "kind", "reason", "text", "delivered_fingerprints", "consent_requested"],
          "properties": {
            "action": {
              "type": "string",
              "enum": ["send", "skip"]
            },
            "kind": {
              "type": "string",
              "enum": ["immediate", "digest"]
            },
            "reason": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "delivered_fingerprints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "consent_requested": {
              "type": "boolean"
            }
          }
        },
        "recommendations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["action", "reason", "text", "reply_to_message_id"],
          "properties": {
            "action": {
              "type": "string",
              "enum": ["send", "skip"]
            },
            "reason": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "reply_to_message_id": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "pending_consent_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint", "chat_id", "asked_at", "expires_at", "question", "summary", "status", "message_id", "accepted_at", "last_error", "recommendations"],
      "properties": {
        "fingerprint": {
          "type": "string"
        },
        "chat_id": {
          "type": "string"
        },
        "asked_at": {
          "type": "string"
        },
        "expires_at": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted"]
        },
        "message_id": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_at": {
          "type": "string"
        },
        "last_error": {
          "type": "string"
        },
        "recommendations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/practical_recommendation"
          }
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_status",
        "notes",
        "delivered_fingerprints",
        "digest_pending",
        "last_update_id",
        "last_checked_at"
      ],
      "properties": {
        "last_seen_fingerprint": {
          "type": "string"
        },
        "last_delivered_fingerprint": {
          "type": "string"
        },
        "last_status": {
          "type": "string",
          "enum": ["delivered", "suppressed", "failed", "investigate", "unknown", "queued"]
        },
        "last_checked_at": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "delivered_fingerprints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "digest_pending": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/digest_entry"
          }
        },
        "last_digest_sent_at": {
          "type": "string"
        },
        "last_update_id": {
          "type": "integer",
          "minimum": 0
        },
        "pending_consent": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/pending_consent_runtime"
            }
          ]
        }
      }
    },
    "telegram_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "consent_enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "consent_enabled": {
          "type": "boolean"
        },
        "chat_id": {
          "type": "string"
        },
        "silent": {
          "type": "boolean"
        },
        "env_file": {
          "type": "string"
        }
      }
    }
  }
}
